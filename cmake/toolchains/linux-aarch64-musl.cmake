set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR aarch64)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

set(PSLOG_MUSL_PREFIX $ENV{HOME}/.local/cross/aarch64-linux-musl)
set(CMAKE_C_COMPILER ${PSLOG_MUSL_PREFIX}/bin/aarch64-linux-musl-gcc CACHE FILEPATH "")
set(CMAKE_AR ${PSLOG_MUSL_PREFIX}/bin/aarch64-linux-musl-ar CACHE FILEPATH "")
set(CMAKE_RANLIB ${PSLOG_MUSL_PREFIX}/bin/aarch64-linux-musl-ranlib CACHE FILEPATH "")
set(CMAKE_SYSROOT ${PSLOG_MUSL_PREFIX}/aarch64-linux-musl CACHE PATH "")

set(CMAKE_FIND_ROOT_PATH ${CMAKE_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)

set(CMAKE_CROSSCOMPILING_EMULATOR /usr/bin/qemu-aarch64;-L;${CMAKE_SYSROOT} CACHE STRING "")

set(PSLOG_TARGET_ARCH aarch64 CACHE STRING "" FORCE)
set(PSLOG_TARGET_OS linux CACHE STRING "" FORCE)
set(PSLOG_TARGET_LIBC musl CACHE STRING "" FORCE)
